generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id       String @id @default(uuid())
  name     String
  slug     String @unique
  document String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  role      UserRole
  email     String   @unique
  password  String
  isOwner   Boolean  @default(false) @map("is_owner")
  isActive  Boolean  @default(true) @map("is_active")
  companyId String   @map("company_id")

  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum UserRole {
  SYSTEM_ADMIN
  COMPANY_ADMIN
  COMPANY_OWNER
  CAREGIVER
}

model Device {
  id           String        @id @default(uuid())
  name         String
  serialNumber String        @unique @map("serial_number")
  companyId    String        @map("company_id")

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  measurements  Measurement[]
  notifications Notification[]

  @@map("devices")
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DECOMMISSIONED
  ERROR
  LOW_BATTERY
  DISCONNECTED
}

model Elderly {
  id        String   @id @default(uuid())
  name      String
  age       String
  document  String
  birthDate DateTime? @map("birth_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("elderly")
}

model Measurement {
  id           String  @id @default(uuid())
  deviceId     String  @map("device_id")
  bpm          Int
  spo2         Int
  fallDetected Boolean @default(false) @map("fall_detected")

  device      Device   @relation(fields: [deviceId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("measurements")
}

model Notification {
  id          String              @id @default(uuid())
  deviceId    String              @map("device_id")
  caregiverId String             @map("caregiver_id")
  type        NotificationType
  status      NotificationStatus  @default(PENDING) @map("notification_status")
  channel     NotificationChannel @default(DASHBOARD) @map("notification_channel")
  message     String

  device      Device   @relation(fields: [deviceId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

enum NotificationType {
  URGENCY
  ATTENTION
  FALL
  LOW_SPO2
  HIGH_BPM
  GENERIC
}

enum NotificationStatus {
  PENDING
  SENT
  READ
}

enum NotificationChannel {
  DASHBOARD
  EMAIL
  WHATSAPP
}

model Plan {
  id           String       @id @default(uuid())
  name         String       @unique
  price        Float
  period       PlanInterval
  isMain       Boolean      @default(false) @map("is_main")
  isActive     Boolean      @default(true) @map("is_active")
  isEnterprise Boolean      @default(false) @map("is_enterprise")

  planBenefits  PlanBenefit[]
  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model PlanBenefit {
  id          String @id @default(uuid())
  title       String
  description String
  planId      String @map("plan_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id])

  @@map("plan_benefits")
}

enum PlanInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Subscription {
  id     String @id @default(uuid())
  planId String @map("plan_id")
  plan   Plan   @relation(fields: [planId], references: [id])

  status      SubscriptionStatus
  startAt     DateTime   @default(now()) @map("start_at")
  endAt       DateTime?  @map("end_at")
  renewAt     DateTime? @map("renew_at")
  trialEndsAt DateTime? @map("trial_ends_at")
  cancelAt   DateTime? @map("cancel_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments SubscriptionPayment[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
  TRIALING
  PAST_DUE
  UNPAID
}

model SubscriptionPayment {
  id             String                @id @default(uuid())
  subscriptionId String                @map("subscription_id")
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id])

  amount        Decimal
  currency      String                  @default("BRL")
  method        PaymentMethod
  status        SubscriptionPaymentStatus
  transactionId String?                 @map("transaction_id")
  attemptAt     DateTime              @default(now()) @map("attempt_at")
  paidAt        DateTime?             @map("paid_at")
  statusReason  String?              @map("status_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription_payments")
}

enum SubscriptionPaymentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PaymentMethod {
  CARD
  PIX
}